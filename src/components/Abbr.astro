---
export interface Props {
  label: string;
  id?: string;
}

const { label, id } = Astro.props;
const tooltipId =
  id ??
  `abbr-${Math.random().toString(36).slice(2, 10)}-${Math.random()
    .toString(36)
    .slice(2, 10)}`;
---

<span class="tooltip">
  <abbr class="trigger" tabindex="0" title={label} aria-describedby={tooltipId}>
    <slot />
  </abbr>
  <span id={tooltipId} role="tooltip" class="content">
    {label}
  </span>
</span>

<style>
  .tooltip {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
  }

  .trigger {
    cursor: help;
    font-size: inherit;
    line-height: inherit;
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-color: color-mix(
      in srgb,
      var(--color-primary) 70%,
      transparent
    );
    border: 0;
  }

  .content {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.65rem);
    z-index: 20;
    width: max-content;
    max-width: min(18rem, calc(100vw - 2rem));
    translate: -50% 0.35rem;
    border: 1px solid var(--color-ic-border);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-ic-bg));
    color: var(--color-text);
    padding: 0.55rem 0.8rem;
    font-size: 0.8rem;
    line-height: 1.35;
    box-shadow:
      0 18px 30px -18px rgb(15 23 42 / 0.4),
      0 10px 18px -14px rgb(15 23 42 / 0.28);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 160ms ease,
      translate 160ms ease;
  }

  .content::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    height: 0.75rem;
    width: 0.75rem;
    translate: -50% -50%;
    rotate: 45deg;
    border-right: 1px solid var(--color-ic-border);
    border-bottom: 1px solid var(--color-ic-border);
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-ic-bg));
  }

  .tooltip:hover .content,
  .tooltip:focus-within .content {
    opacity: 1;
    translate: -50% 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .content {
      transition: opacity 0.01ms linear;
    }
  }
</style>
